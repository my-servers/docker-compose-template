{
  "schema": [
    {
      "key": "container_name",
      "label": "容器名称",
      "description": "Docker 容器名称",
      "placeholder": "immich-server",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "immich-server"
    },
    {
      "key": "timezone",
      "label": "时区",
      "description": "容器运行时区",
      "placeholder": "Asia/Shanghai",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "Asia/Shanghai"
    },
    {
      "key": "http_port",
      "label": "访问端口",
      "description": "Immich Web 页面端口",
      "placeholder": 2283,
      "value_type": "number",
      "input": "number",
      "required": true,
      "default_value": "2283"
    },
    {
      "key": "db_password",
      "label": "数据库密码",
      "description": "Immich PostgreSQL 密码",
      "placeholder": "immich",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "immich"
    },
    {
      "key": "uploads_dir",
      "label": "照片目录",
      "description": "Immich 上传照片目录",
      "placeholder": "./library",
      "value_type": "string",
      "input": "path",
      "required": true,
      "default_value": "./library"
    },
    {
      "key": "db_dir",
      "label": "数据库目录",
      "description": "PostgreSQL 数据目录",
      "placeholder": "./postgres",
      "value_type": "string",
      "input": "path",
      "required": true,
      "default_value": "./postgres"
    }
  ],
  "groups": []
}
