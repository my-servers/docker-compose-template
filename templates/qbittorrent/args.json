{
  "schema": [
    {
      "key": "container_name",
      "label": "容器名称",
      "description": "Docker 容器名称",
      "placeholder": "qbittorrent",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "qbittorrent"
    },
    {
      "key": "timezone",
      "label": "时区",
      "description": "容器运行时区",
      "placeholder": "Asia/Shanghai",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "Asia/Shanghai"
    },
    {
      "key": "puid",
      "label": "PUID",
      "description": "宿主机用户 ID，群晖/飞牛常见为 1000",
      "placeholder": 1000,
      "value_type": "number",
      "input": "number",
      "required": true,
      "default_value": "1000"
    },
    {
      "key": "pgid",
      "label": "PGID",
      "description": "宿主机用户组 ID，群晖/飞牛常见为 1000",
      "placeholder": 1000,
      "value_type": "number",
      "input": "number",
      "required": true,
      "default_value": "1000"
    },
    {
      "key": "webui_port",
      "label": "WebUI 端口",
      "description": "浏览器访问 qBittorrent 的端口",
      "placeholder": 8080,
      "value_type": "number",
      "input": "number",
      "required": true,
      "default_value": "8080"
    },
    {
      "key": "config_dir",
      "label": "配置目录",
