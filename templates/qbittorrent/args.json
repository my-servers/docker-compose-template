      "value_type": "string",
      "input": "path",
      "required": true,
      "default_value": "./config"
    },
    {
      "key": "downloads_dir",
      "label": "下载目录",
      "description": "下载文件保存目录",
      "placeholder": "./downloads",
      "value_type": "string",
      "input": "path",
      "required": true,
      "default_value": "./downloads"
