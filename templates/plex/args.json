{
  "schema": [
    {
      "key": "container_name",
      "label": "容器名称",
      "description": "Docker 容器名称",
      "placeholder": "plex",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "plex"
    },
    {
      "key": "timezone",
      "label": "时区",
      "description": "容器运行时区",
      "placeholder": "Asia/Shanghai",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "Asia/Shanghai"
    },
    {
      "key": "puid",
      "label": "PUID",
      "description": "宿主机用户 ID，群晖/飞牛常见为 1000",
      "placeholder": "1000",
      "value_type": "number",
      "input": "number",
      "required": true,
      "default_value": "1000"
    },
    {
      "key": "pgid",
      "label": "PGID",
      "description": "宿主机用户组 ID，群晖/飞牛常见为 1000",
      "placeholder": "1000",
      "value_type": "number",
      "input": "number",
      "required": true,
      "default_value": "1000"
    },
    {
      "key": "plex_claim",
      "label": "Claim Token",
      "description": "首次绑定 Plex 账号时可填写，可留空",
      "placeholder": "",
      "value_type": "string",
      "input": "text",
      "required": false,
      "default_value": ""
    }
  ],
