{
  "schema": [
    {
      "key": "container_name",
      "label": "容器名称",
      "description": "Docker 容器名称",
      "placeholder": "bookstack",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "bookstack"
    },
    {
      "key": "timezone",
      "label": "时区",
      "description": "容器运行时区",
      "placeholder": "Asia/Shanghai",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "Asia/Shanghai"
    },
    {
      "key": "puid",
      "label": "PUID",
      "description": "宿主机用户 ID，群晖/飞牛常见为 1000",
      "placeholder": "1000",
      "value_type": "number",
      "input": "number",
      "required": true,
      "default_value": "1000"
    },
    {
      "key": "pgid",
      "label": "PGID",
      "description": "宿主机用户组 ID，群晖/飞牛常见为 1000",
      "placeholder": "1000",
      "value_type": "number",
      "input": "number",
      "required": true,
      "default_value": "1000"
    },
    {
      "key": "app_url",
      "label": "访问地址",
      "description": "BookStack 对外访问地址，默认端口 6875",
      "placeholder": "http://localhost:6875",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "http://localhost:6875"
    },
    {
      "key": "app_key",
      "label": "应用密钥",
      "description": "Laravel 应用密钥，默认值可直接启动，公网环境建议改成随机值",
      "placeholder": "base64:WkKZ/61BD9KeQec/vQs3DO8tsHxZogGv1SirSQY87Pc=",
      "value_type": "string",
      "input": "password",
      "required": true,
      "default_value": "base64:WkKZ/61BD9KeQec/vQs3DO8tsHxZogGv1SirSQY87Pc="
    },
    {
      "key": "db_name",
      "label": "数据库名",
      "description": "BookStack 使用的数据库名",
      "placeholder": "bookstack",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "bookstack"
    },
    {
      "key": "db_user",
      "label": "数据库用户",
      "description": "BookStack 数据库用户名",
      "placeholder": "bookstack",
      "value_type": "string",
      "input": "text",
      "required": true,
      "default_value": "bookstack"
    },
    {
      "key": "db_password",
      "label": "数据库密码",
      "description": "BookStack 数据库密码",
      "placeholder": "bookstack",
      "value_type": "string",
      "input": "password",
      "required": true,
      "default_value": "bookstack"
    },
    {
      "key": "db_root_password",
      "label": "数据库 Root 密码",
      "description": "MariaDB Root 密码，默认值可直接启动",
      "placeholder": "bookstack-root",
      "value_type": "string",
      "input": "password",
      "required": true,
      "default_value": "bookstack-root"
    }
  ],
  "groups": [
    {
      "key": "ports",
      "label": "端口映射",
      "description": "支持添加多个端口映射",
      "item_label": "端口",
      "min_items": 1,
      "fields": [
        {
          "key": "host",
          "label": "宿主机端口",
          "description": "暴露到宿主机的端口",
          "placeholder": "6875",
          "value_type": "number",
          "input": "number",
          "required": true,
          "default_value": "6875"
        },
        {
          "key": "container",
          "label": "容器端口",
          "description": "容器内部监听端口",
          "placeholder": "80",
          "value_type": "number",
          "input": "number",
          "required": true,
          "default_value": "80"
        },
        {
          "key": "protocol",
          "label": "协议",
          "description": "端口协议",
          "value_type": "string",
          "input": "select",
          "required": true,
          "default_value": "tcp",
          "options": [
            {
              "label": "TCP",
              "value": "tcp"
            },
            {
              "label": "UDP",
              "value": "udp"
            }
          ]
        }
      ],
      "default_items": [
        {
          "fields": [
            {
              "key": "host",
              "label": "宿主机端口",
              "description": "暴露到宿主机的端口",
              "placeholder": "6875",
              "value_type": "number",
              "input": "number",
              "required": true,
              "default_value": "6875"
            },
            {
              "key": "container",
              "label": "容器端口",
              "description": "容器内部监听端口",
              "placeholder": "80",
              "value_type": "number",
              "input": "number",
              "required": true,
              "default_value": "80"
            },
            {
              "key": "protocol",
              "label": "协议",
              "description": "端口协议",
              "value_type": "string",
              "input": "select",
              "required": true,
              "default_value": "tcp",
              "options": [
                {
                  "label": "TCP",
                  "value": "tcp"
                },
                {
                  "label": "UDP",
                  "value": "udp"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "key": "app_volumes",
      "label": "应用目录映射",
      "description": "支持添加多个目录挂载",
      "item_label": "目录",
      "min_items": 1,
      "fields": [
        {
          "key": "source",
          "label": "宿主机目录",
          "description": "宿主机目录路径",
          "placeholder": "./config",
          "value_type": "string",
          "input": "path",
          "required": true,
          "default_value": "./config"
        },
        {
          "key": "target",
          "label": "容器目录",
          "description": "容器内目录路径",
          "placeholder": "/config",
          "value_type": "string",
          "input": "path",
          "required": true,
          "default_value": "/config"
        },
        {
          "key": "mode",
          "label": "挂载模式",
          "description": "目录挂载模式",
          "value_type": "string",
          "input": "select",
          "required": true,
          "default_value": "rw",
          "options": [
            {
              "label": "只读",
              "value": "ro"
            },
            {
              "label": "读写",
              "value": "rw"
            }
          ]
        }
      ],
      "default_items": [
